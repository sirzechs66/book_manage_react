{
  "name": "book-management-system",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "node server/index.js",
    "build": "cd client && npm install && npm run build",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npm start"
  },
  "engines": {
    "node": ">=18 <=20"
  },
  "dependencies": {
    "concurrently": "^8.2.2",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "nodemon": "^3.0.3",
    "pg": "^8.11.3"
  }
}
